<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/admin_paywall_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:text="@string/admin_paywall_message"
                android:textColor="#EBFFFFFF"
                android:textSize="17sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonContactAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:minHeight="52dp"
                android:text="@string/admin_paywall_contact_button"
                android:textAllCaps="false"
                android:textColor="@color/text_primary_light"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#F5F5F5"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRetryLogin"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="52dp"
                android:text="@string/admin_paywall_retry_login"
                android:textAllCaps="false"
                android:textColor="#F5F5F5"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:strokeColor="#59FFFFFF"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
