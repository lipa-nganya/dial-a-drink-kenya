<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DialADrinkDriver.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>

    <style name="Theme.DialADrinkDriver" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorSurface">@color/paper_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorOnBackground">@color/text_primary_dark</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorHint">@color/text_secondary_dark</item>
        <item name="textInputStyle">@style/Widget.DialADrinkDriver.TextInputLayout</item>
        <item name="editTextStyle">@style/Widget.DialADrinkDriver.TextInputEditText</item>
        <item name="popupMenuStyle">@style/Widget.DialADrinkDriver.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.DialADrinkDriver.PopupMenu</item>
    </style>
    
    <style name="Theme.DialADrinkDriver.FullScreen" parent="Theme.DialADrinkDriver">
        <item name="android:windowFullscreen">true</item>
    </style>
    
    <!-- Dark theme for AlertDialog: visible text and green accent -->
    <style name="Theme.DialADrinkDriver.AlertDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@color/paper_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_primary_dark</item>
        <item name="android:colorForeground">@color/text_primary_dark</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
        <item name="materialButtonStyle">@style/Widget.DialADrinkDriver.AlertDialog.Button</item>
        <item name="android:alertDialogTheme">@style/Theme.DialADrinkDriver.AlertDialog</item>
        <item name="alertDialogTheme">@style/Theme.DialADrinkDriver.AlertDialog</item>
    </style>

    <!-- Black background variant for POS dialogs -->
    <style name="Theme.DialADrinkDriver.AlertDialog.Black" parent="Theme.DialADrinkDriver.AlertDialog">
        <item name="android:windowBackground">@color/background_dark</item>
    </style>
    <style name="Widget.DialADrinkDriver.AlertDialog.Button" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent</item>
        <item name="background">@drawable/button_border_green</item>
    </style>
    
    <!-- Dark theme for DatePickerDialog -->
    <style name="Theme.DialADrinkDriver.DatePickerDialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@color/paper_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
    </style>
    
    <!-- Global style for TextInputEditText to ensure white text -->
    <style name="Widget.DialADrinkDriver.TextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:textColorHint">@color/text_secondary_dark</item>
    </style>

    <!-- Global outlined TextInputLayout colors for dark backgrounds -->
    <style name="Widget.DialADrinkDriver.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="hintTextColor">@color/text_secondary_dark</item>
        <item name="boxBackgroundColor">@color/paper_dark</item>
        <item name="boxStrokeColor">@color/accent</item>
    </style>
    
    <!-- Global style for EditText to ensure white text -->
    <style name="Widget.DialADrinkDriver.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:textColorHint">@color/text_secondary_dark</item>
    </style>
    
    <!-- Dark theme for PopupMenu -->
    <style name="Widget.DialADrinkDriver.PopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@color/paper_dark</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
    </style>
</resources>

